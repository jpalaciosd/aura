# ============================================================================
# AURA Bienestar Estético — Variables de entorno
# Copia este archivo a `.env.local` y rellena los valores.
# Nunca subas `.env.local` al repo.
# ============================================================================

# ---- Supabase (proyecto NUEVO de AURA, no compartido con VRTX) ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ---- OpenAI (chat existente + OCR de comprobantes) ----
OPENAI_API_KEY=sk-...

# ---- ElevenLabs (voz del chat Aura, ya en uso) ----
ELEVENLABS_API_KEY=sk_...

# ---- Nequi (validación de comprobantes de pago) ----
# Estos datos aparecen en los comprobantes que la clienta sube.
NEQUI_NUMERO_DISPLAY=0093128200996
NEQUI_NUMERO_LAST4=0996
NEQUI_TITULAR=AURA Bienestar Estético
PAGOS_VENTANA_VALIDEZ_HORAS=24

# Las NEXT_PUBLIC se muestran al cliente en la pantalla de pago
NEXT_PUBLIC_NEQUI_NUMERO_DISPLAY=0093128200996
NEXT_PUBLIC_NEQUI_TITULAR=AURA Bienestar Estético

# ---- Bootstrap admin ----
# Email que será promovido a admin en su primer login con Google.
# Debe ir en ambas variables (la NEXT_PUBLIC es leída por AuthContext en el cliente).
ADMIN_EMAIL_SEED=juandiegopalaciosdelgado@gmail.com
NEXT_PUBLIC_ADMIN_EMAIL_SEED=juandiegopalaciosdelgado@gmail.com

# ---- Vercel / WhatsApp ----
